FROM python:3.11-slim

WORKDIR /app

# Install language runtimes for multi-language code execution
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    default-jdk \
    nodejs \
    npm \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast dependency installation
RUN pip install uv

# Copy all project files needed for installation
COPY pyproject.toml .
COPY agent/ ./agent/
COPY server.py .

# Install dependencies using editable mode
RUN uv pip install --system --no-build-isolation -e .

EXPOSE 8000

CMD ["python", "server.py"]
